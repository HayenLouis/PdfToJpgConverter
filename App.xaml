<Application x:Class="PdfToJpgConverter.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Dark theme defaults (medium-dark grey, VS Code style) -->
        <SolidColorBrush x:Key="WindowBg"         Color="#1E1E1E"/>
        <SolidColorBrush x:Key="TitleBarBg"        Color="#252526"/>
        <SolidColorBrush x:Key="CardBg"            Color="#2D2D2D"/>
        <SolidColorBrush x:Key="DropZoneBg"        Color="#252525"/>
        <SolidColorBrush x:Key="ItemRowBg"         Color="#333333"/>
        <SolidColorBrush x:Key="BorderBrush"       Color="#404040"/>
        <SolidColorBrush x:Key="AccentBrush"       Color="#049DD9"/>
        <SolidColorBrush x:Key="AccentHoverBrush"  Color="#0378A6"/>
        <SolidColorBrush x:Key="TextPrimary"       Color="#D4D4D4"/>
        <SolidColorBrush x:Key="TextSecondary"     Color="#888888"/>
        <SolidColorBrush x:Key="TextMuted"         Color="#555555"/>
        <SolidColorBrush x:Key="DangerBrush"       Color="#E05555"/>
        <SolidColorBrush x:Key="SuccessBrush"      Color="#3DBD85"/>
        <SolidColorBrush x:Key="ProgressBg"        Color="#333333"/>
        <SolidColorBrush x:Key="InputBg"           Color="#252525"/>
    </Application.Resources>
</Application>
