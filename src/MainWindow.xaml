<Window x:Class="PdfToJpgConverter.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="PDF to JPG Converter"
        Height="720" Width="820"
        MinHeight="580" MinWidth="660"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>

        <!-- ── Accent button ── -->
        <Style x:Key="AccentButton" TargetType="Button">
            <Setter Property="Background"      Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Foreground"      Value="#FFFFFF"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="5" SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{DynamicResource AccentHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Ghost button ── -->
        <Style x:Key="GhostButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="8,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#14049DD9"/>
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Outline button ── -->
        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="Medium"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="14,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#18049DD9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── DPI preset chip button ── -->
        <Style x:Key="DpiPresetBtn" TargetType="Button">
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Padding"         Value="10,4"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#18049DD9"/>
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Title-bar icon button ── -->
        <Style x:Key="TitleBarBtn" TargetType="Button">
            <Setter Property="Width"           Value="30"/>
            <Setter Property="Height"          Value="30"/>
            <Setter Property="Background"      Value="Transparent"/>
            <Setter Property="Foreground"      Value="{DynamicResource TextSecondary}"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="#18049DD9"/>
                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Close button ── -->
        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource TitleBarBtn}">
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#C0E53935"/>
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ── Settings TextBox ── -->
        <Style x:Key="SettingsTextBox" TargetType="TextBox">
            <Setter Property="Background"     Value="{DynamicResource InputBg}"/>
            <Setter Property="Foreground"     Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush"    Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize"       Value="12"/>
            <Setter Property="Padding"        Value="6,5"/>
            <Setter Property="CaretBrush"     Value="{DynamicResource AccentBrush}"/>
            <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Minimal scrollbar ── -->
        <Style x:Key="ThinScrollbar" TargetType="ScrollBar">
            <Setter Property="Width"      Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{DynamicResource TextMuted}"
                                                        CornerRadius="2" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ThinScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <ScrollContentPresenter Grid.Column="0"
                                                    CanContentScroll="{TemplateBinding CanContentScroll}"/>
                            <ScrollBar Grid.Column="1"
                                       x:Name="PART_VerticalScrollBar"
                                       Style="{StaticResource ThinScrollbar}"
                                       Value="{TemplateBinding VerticalOffset}"
                                       Maximum="{TemplateBinding ScrollableHeight}"
                                       ViewportSize="{TemplateBinding ViewportHeight}"
                                       Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Quality slider ── -->
        <Style x:Key="SettingsSlider" TargetType="Slider">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid VerticalAlignment="Center">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Track Grid.Row="1" x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2"
                                                        Background="{DynamicResource AccentBrush}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Width="14" Height="14" CornerRadius="7"
                                                        Background="{DynamicResource AccentBrush}"
                                                        BorderBrush="{DynamicResource WindowBg}"
                                                        BorderThickness="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" CornerRadius="2"
                                                        Background="{DynamicResource BorderBrush}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <!-- ══ Root chrome ══ -->
    <Border x:Name="RootBorder"
            CornerRadius="8"
            Background="{DynamicResource WindowBg}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="3" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- ══ TITLE BAR ══ -->
            <Border Grid.Row="0"
                    Background="{DynamicResource TitleBarBg}"
                    CornerRadius="8,8,0,0"
                    MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid Margin="16,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="3" Height="16" CornerRadius="1.5"
                                Background="{DynamicResource AccentBrush}" Margin="0,0,10,0"/>
                        <TextBlock Text="PDF to JPG"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="SettingsBtn"
                                Style="{StaticResource TitleBarBtn}"
                                Margin="0,0,2,0"
                                ToolTip="Settings"
                                Click="Settings_Click">
                            <TextBlock x:Name="SettingsIcon" Text="⚙" FontSize="13"/>
                        </Button>
                        <Button Style="{StaticResource TitleBarBtn}" Margin="0,0,2,0" Click="Minimize_Click">
                            <TextBlock Text="—" FontSize="10" Margin="0,0,0,2"/>
                        </Button>
                        <Button Style="{StaticResource CloseBtn}" Click="Close_Click">
                            <TextBlock Text="✕" FontSize="10"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══ MAIN CONTENT ══ -->
            <ScrollViewer x:Name="MainScroll"
                          Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource ThinScrollViewer}">
                <StackPanel Margin="24,20,24,24">

                    <!-- ▸ DROP ZONE ◂ -->
                    <Border x:Name="DropZone"
                            Background="{DynamicResource DropZoneBg}"
                            CornerRadius="6"
                            Height="150"
                            Margin="0,0,0,14"
                            Cursor="Hand"
                            AllowDrop="True"
                            MouseLeftButtonDown="DropZone_Click"
                            DragOver="DropZone_DragOver"
                            DragLeave="DropZone_DragLeave"
                            Drop="DropZone_Drop">
                        <Border.BorderBrush>
                            <DrawingBrush TileMode="Tile"
                                          Viewport="0,0,12,12" ViewportUnits="Absolute"
                                          Viewbox="0,0,12,12"  ViewboxUnits="Absolute">
                                <DrawingBrush.Drawing>
                                    <GeometryDrawing>
                                        <GeometryDrawing.Pen>
                                            <Pen Brush="{DynamicResource TextMuted}" Thickness="1.5"
                                                 DashStyle="{x:Static DashStyles.Dash}"/>
                                        </GeometryDrawing.Pen>
                                        <GeometryDrawing.Geometry>
                                            <RectangleGeometry Rect="0.75,0.75,10.5,10.5"/>
                                        </GeometryDrawing.Geometry>
                                    </GeometryDrawing>
                                </DrawingBrush.Drawing>
                            </DrawingBrush>
                        </Border.BorderBrush>
                        <Border.BorderThickness>1</Border.BorderThickness>

                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock Text="Drop PDF files here"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="14" FontWeight="Medium"
                                       HorizontalAlignment="Center" Margin="0,0,0,4"/>
                            <TextBlock Text="or click to browse"
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- ▸ FILE LIST ◂ -->
                    <Grid Margin="0,0,0,14">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="FILES"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border x:Name="FileBadge"
                                        Background="{DynamicResource AccentBrush}"
                                        CornerRadius="3" Padding="6,1"
                                        Margin="8,0,0,0"
                                        Visibility="Collapsed">
                                    <TextBlock x:Name="FileBadgeText"
                                               Foreground="White" FontSize="10" FontWeight="Bold"/>
                                </Border>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Content="Clear all"
                                    Style="{StaticResource GhostButton}"
                                    Foreground="{DynamicResource DangerBrush}"
                                    Click="ClearAll_Click"
                                    x:Name="ClearAllBtn"
                                    Visibility="Collapsed"/>
                        </Grid>

                        <Border Grid.Row="1"
                                Background="{DynamicResource CardBg}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1" CornerRadius="6"
                                x:Name="FileListBorder"
                                Visibility="Collapsed">
                            <ItemsControl x:Name="FileListBox" Padding="4">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource ItemRowBg}"
                                                CornerRadius="4" Margin="0,2" Padding="10,7">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding FileName}"
                                                               Foreground="{DynamicResource TextPrimary}"
                                                               FontSize="12" FontWeight="Medium"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Directory}"
                                                               Foreground="{DynamicResource TextSecondary}"
                                                               FontSize="11"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,1,0,0"/>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Style="{StaticResource TitleBarBtn}"
                                                        Width="24" Height="24"
                                                        Tag="{Binding FullPath}"
                                                        Click="RemoveFile_Click"
                                                        ToolTip="Remove">
                                                    <TextBlock Text="✕"
                                                               Foreground="{DynamicResource TextMuted}"
                                                               FontSize="9"/>
                                                </Button>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>

                        <TextBlock Grid.Row="1"
                                   x:Name="EmptyHint"
                                   Text="No files added — drop PDFs above or click the zone."
                                   Foreground="{DynamicResource TextMuted}"
                                   FontSize="12"
                                   HorizontalAlignment="Center"
                                   Margin="0,4"/>
                    </Grid>

                    <!-- ▸ OUTPUT LOCATION ◂ -->
                    <Border Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="14,12" Margin="0,0,0,14">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="OUTPUT LOCATION"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="10" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Border Grid.Column="1"
                                        Background="{DynamicResource ProgressBg}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="5"
                                        Padding="2">
                                    <StackPanel Orientation="Horizontal">
                                        <Border x:Name="SegCustom"
                                                CornerRadius="4" Padding="10,4"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="SegCustom_Click">
                                            <TextBlock x:Name="SegCustomText"
                                                       Text="Custom folder"
                                                       FontSize="11" FontWeight="Medium"/>
                                        </Border>
                                        <Border x:Name="SegNextTo"
                                                CornerRadius="4" Padding="10,4"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="SegNextTo_Click">
                                            <TextBlock x:Name="SegNextToText"
                                                       Text="Next to PDF"
                                                       FontSize="11" FontWeight="Medium"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid x:Name="CustomFolderRow">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="OutputPathText"
                                           Grid.Column="0"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"
                                           VerticalAlignment="Center"/>
                                <Button Grid.Column="1"
                                        Content="Browse…"
                                        Style="{StaticResource OutlineButton}"
                                        Click="BrowseOutput_Click"
                                        Margin="12,0,0,0"
                                        VerticalAlignment="Center"/>
                            </Grid>

                            <TextBlock x:Name="NextToPdfHint"
                                       Text="Images will be saved in the same folder as each source PDF."
                                       Foreground="{DynamicResource TextSecondary}"
                                       FontSize="12"
                                       Visibility="Collapsed"/>
                        </StackPanel>
                    </Border>

                    <!-- ▸ PROGRESS ◂ -->
                    <Border x:Name="ProgressSection"
                            Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="14,12" Margin="0,0,0,14"
                            Visibility="Collapsed">
                        <StackPanel>
                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock x:Name="StatusText"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="12"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="ProgressPct"
                                           Grid.Column="1"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontSize="12" FontWeight="SemiBold"
                                           Margin="12,0,0,0"/>
                            </Grid>
                            <Border x:Name="ProgressTrack"
                                    Height="5" CornerRadius="2.5"
                                    Background="{DynamicResource ProgressBg}"
                                    SizeChanged="ProgressTrack_SizeChanged">
                                <Border x:Name="ProgressFill"
                                        HorizontalAlignment="Left"
                                        Height="5" CornerRadius="2.5"
                                        Background="{DynamicResource AccentBrush}"
                                        Width="0"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ▸ CONVERT BUTTON ◂ -->
                    <Button x:Name="ConvertBtn"
                            Style="{StaticResource AccentButton}"
                            Height="44"
                            Click="ConvertBtn_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="ConvertBtnIcon"  Text="⚡" FontSize="14"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="ConvertBtnLabel" Text="Convert to JPG"
                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                </StackPanel>
            </ScrollViewer>

            <!-- ══ SETTINGS PANEL ══ -->
            <ScrollViewer x:Name="SettingsScroll"
                          Grid.Row="1"
                          Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Style="{StaticResource ThinScrollViewer}">
                <StackPanel Margin="24,20,24,24">

                    <!-- Header -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="SETTINGS"
                                   Foreground="{DynamicResource TextSecondary}"
                                   FontSize="10" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                        <Button Grid.Column="1"
                                Content="← Back"
                                Style="{StaticResource GhostButton}"
                                Click="Settings_Click"/>
                    </Grid>

                    <!-- ── RENDERING section ── -->
                    <TextBlock Text="RENDERING"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="10" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <Border Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="14,0" Margin="0,0,0,20">
                        <StackPanel>

                            <!-- Color mode -->
                            <Grid Margin="0,14,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Color mode"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="13" FontWeight="Medium"/>
                                    <TextBlock Text="Color space for the exported images"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border Grid.Column="1"
                                        Background="{DynamicResource ProgressBg}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="1" CornerRadius="5"
                                        Padding="2">
                                    <StackPanel Orientation="Horizontal">
                                        <Border x:Name="CmColorSeg"
                                                CornerRadius="4" Padding="10,4"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="ColorModeColor_Click">
                                            <TextBlock x:Name="CmColorText"
                                                       Text="Color"
                                                       FontSize="11" FontWeight="Medium"/>
                                        </Border>
                                        <Border x:Name="CmGraySeg"
                                                CornerRadius="4" Padding="10,4"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="ColorModeGray_Click">
                                            <TextBlock x:Name="CmGrayText"
                                                       Text="Grayscale"
                                                       FontSize="11" FontWeight="Medium"/>
                                        </Border>
                                        <Border x:Name="CmBWSeg"
                                                CornerRadius="4" Padding="10,4"
                                                Cursor="Hand"
                                                MouseLeftButtonDown="ColorModeBW_Click">
                                            <TextBlock x:Name="CmBWText"
                                                       Text="B&amp;W"
                                                       FontSize="11" FontWeight="Medium"/>
                                        </Border>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="-14,0"/>

                            <!-- DPI -->
                            <Grid Margin="0,14,0,14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Output DPI"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="13" FontWeight="Medium"/>
                                        <TextBlock Text="Higher DPI = better quality, larger files"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBox x:Name="DpiBox"
                                             Grid.Column="1"
                                             Style="{StaticResource SettingsTextBox}"
                                             Width="80"
                                             TextAlignment="Center"
                                             Text="300"
                                             PreviewTextInput="DpiBox_PreviewTextInput"
                                             LostFocus="DpiBox_LostFocus"/>
                                </Grid>
                                <!-- DPI preset chips -->
                                <StackPanel Grid.Row="1" Orientation="Horizontal">
                                    <Button Content="72"  Style="{StaticResource DpiPresetBtn}" Tag="72"  Click="DpiPreset_Click" Margin="0,0,6,0"/>
                                    <Button Content="96"  Style="{StaticResource DpiPresetBtn}" Tag="96"  Click="DpiPreset_Click" Margin="0,0,6,0"/>
                                    <Button Content="150" Style="{StaticResource DpiPresetBtn}" Tag="150" Click="DpiPreset_Click" Margin="0,0,6,0"/>
                                    <Button Content="200" Style="{StaticResource DpiPresetBtn}" Tag="200" Click="DpiPreset_Click" Margin="0,0,6,0"/>
                                    <Button Content="300" Style="{StaticResource DpiPresetBtn}" Tag="300" Click="DpiPreset_Click" Margin="0,0,6,0"/>
                                    <Button Content="600" Style="{StaticResource DpiPresetBtn}" Tag="600" Click="DpiPreset_Click"/>
                                </StackPanel>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="-14,0"/>

                            <!-- JPEG Quality -->
                            <Grid Margin="0,14,0,14">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <Grid Grid.Row="0" Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="JPEG Quality"
                                                   Foreground="{DynamicResource TextPrimary}"
                                                   FontSize="13" FontWeight="Medium"/>
                                        <TextBlock Text="Lower quality = smaller file size"
                                                   Foreground="{DynamicResource TextSecondary}"
                                                   FontSize="11" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <TextBlock x:Name="QualityLabel"
                                               Grid.Column="1"
                                               Foreground="{DynamicResource AccentBrush}"
                                               FontSize="13" FontWeight="SemiBold"
                                               VerticalAlignment="Center"/>
                                </Grid>
                                <Slider x:Name="QualitySlider"
                                        Grid.Row="1"
                                        Style="{StaticResource SettingsSlider}"
                                        Minimum="10" Maximum="100" SmallChange="1" LargeChange="5"
                                        ValueChanged="QualitySlider_ValueChanged"/>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="-14,0"/>

                            <!-- Landscape rotation -->
                            <Grid Margin="0,14,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Rotate landscape pages"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="13" FontWeight="Medium"/>
                                    <TextBlock Text="Rotates wide pages 90° CCW to portrait orientation"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border x:Name="RotateToggleBorder"
                                        Grid.Column="1"
                                        Width="42" Height="22"
                                        CornerRadius="11"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="RotateToggle_Click">
                                    <Border x:Name="RotateThumb"
                                            Width="16" Height="16"
                                            CornerRadius="8"
                                            Background="White"
                                            HorizontalAlignment="Left"
                                            Margin="3,0,0,0"/>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- ── OUTPUT section ── -->
                    <TextBlock Text="OUTPUT"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="10" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <Border Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="14,0" Margin="0,0,0,20">
                        <StackPanel>

                            <!-- Default export folder -->
                            <Grid Margin="0,14,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                                    <TextBlock Text="Default export folder"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="13" FontWeight="Medium"/>
                                    <TextBlock x:Name="SettingsOutputPath"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11" Margin="0,2,0,0"
                                               TextTrimming="CharacterEllipsis"/>
                                </StackPanel>
                                <Button Grid.Column="1"
                                        Content="Browse…"
                                        Style="{StaticResource OutlineButton}"
                                        Click="SettingsBrowseOutput_Click"
                                        VerticalAlignment="Center"/>
                            </Grid>

                            <Border Height="1" Background="{DynamicResource BorderBrush}" Margin="-14,0"/>

                            <!-- Subfolder per PDF -->
                            <Grid Margin="0,14,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Create subfolder per PDF"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="13" FontWeight="Medium"/>
                                    <TextBlock Text="Groups output into a folder named after the PDF"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border x:Name="SubfolderToggleBorder"
                                        Grid.Column="1"
                                        Width="42" Height="22"
                                        CornerRadius="11"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="SubfolderToggle_Click">
                                    <Border x:Name="SubfolderThumb"
                                            Width="16" Height="16"
                                            CornerRadius="8"
                                            Background="White"
                                            HorizontalAlignment="Left"
                                            Margin="3,0,0,0"/>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- ── APPEARANCE section ── -->
                    <TextBlock Text="APPEARANCE"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="10" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <Border Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="14,0" Margin="0,0,0,20">
                        <StackPanel>

                            <!-- Dark mode toggle -->
                            <Grid Margin="0,14,0,14">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Dark mode"
                                               Foreground="{DynamicResource TextPrimary}"
                                               FontSize="13" FontWeight="Medium"/>
                                    <TextBlock Text="Toggle between dark and light theme"
                                               Foreground="{DynamicResource TextSecondary}"
                                               FontSize="11" Margin="0,2,0,0"/>
                                </StackPanel>
                                <Border x:Name="ThemeToggleBorder"
                                        Grid.Column="1"
                                        Width="42" Height="22"
                                        CornerRadius="11"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="ThemeToggle_Click">
                                    <Border x:Name="ThemeThumb"
                                            Width="16" Height="16"
                                            CornerRadius="8"
                                            Background="White"
                                            HorizontalAlignment="Left"
                                            Margin="3,0,0,0"/>
                                </Border>
                            </Grid>

                        </StackPanel>
                    </Border>

                    <!-- ── About / Version ── -->
                    <TextBlock Text="ABOUT"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="10" FontWeight="SemiBold"
                               Margin="0,0,0,8"/>

                    <Border Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1" CornerRadius="6"
                            Padding="14,12" Margin="0,0,0,20">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="PDF to JPG Converter"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="13" FontWeight="Medium"/>
                                <TextBlock Text="by HMZ"
                                           Foreground="{DynamicResource TextSecondary}"
                                           FontSize="11" Margin="0,2,0,0"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Text="v1.2"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontSize="13" FontWeight="SemiBold"
                                       VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                </StackPanel>
            </ScrollViewer>

        </Grid>
    </Border>
</Window>
